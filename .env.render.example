# AstraForge Backend — Render Environment Variables
# Copy KEY names to Render > Environment. Replace placeholder values with your real values.

ASTRAFORGE_ENVIRONMENT=production
ASTRAFORGE_LOG_LEVEL=INFO
ASTRAFORGE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
ASTRAFORGE_CORS_ORIGINS=["https://YOUR-VERCEL-APP.vercel.app"]
ASTRAFORGE_CORS_ALLOW_CREDENTIALS=false

ASTRAFORGE_MUTATION_AUTH_REQUIRED=true
ASTRAFORGE_MUTATION_API_TOKEN=CHANGE_TO_32_PLUS_CHARACTER_RANDOM_TOKEN
ASTRAFORGE_MUTATION_REPLAY_TTL_SECONDS=900
ASTRAFORGE_MUTATION_REPLAY_CACHE_LIMIT=5000

# Demo execution switch. Keep false until env + risk + Binance Demo keys are confirmed.
ASTRAFORGE_EXECUTION_ENABLED=false
ASTRAFORGE_EXECUTION_TAKE_PROFIT_R_MULTIPLE=2
ASTRAFORGE_SCANNER_AUTO_START=true

ASTRAFORGE_BINANCE_PUBLIC_BASE_URL=https://fapi.binance.com
ASTRAFORGE_BINANCE_DEMO_BASE_URL=https://demo-fapi.binance.com
ASTRAFORGE_BINANCE_DEMO_API_KEY=YOUR_BINANCE_DEMO_API_KEY
ASTRAFORGE_BINANCE_DEMO_API_SECRET=YOUR_BINANCE_DEMO_API_SECRET
ASTRAFORGE_BINANCE_DEMO_RECV_WINDOW_MS=5000

# Percent format: 1 = 1% risk per trade, not 0.01.
ASTRAFORGE_RISK_PER_TRADE_PERCENT=1
ASTRAFORGE_RISK_DAILY_LOSS_LIMIT_PERCENT=3
ASTRAFORGE_RISK_DAILY_PROFIT_LOCK_PERCENT=5
ASTRAFORGE_RISK_MAX_OPEN_TRADES=3
ASTRAFORGE_RISK_MAX_MARGIN_EXPOSURE_USDT=100
